# .env — Variables d'environnement pour l'agent
# Copiez ce fichier en .env et remplissez vos clés API

# Recherche web — Gratuit sur https://tavily.com
TAVILY_API_KEY=votre_clé_ici

# Légifrance (optionnel) — Inscription sur https://piste.gouv.fr
# Sans ces clés, l'outil fonctionne en mode démo
LEGIFRANCE_CLIENT_ID=votre_client_id_ici
LEGIFRANCE_CLIENT_SECRET=votre_client_secret_ici
